    # URL de l'API backend (avec /users) - pour les appels API authentifiés
VITE_API_URL=http://localhost:3000/api/users

# URL de base de l'API (sans /users) - pour les routes publiques
VITE_API_BASE_URL=http://localhost:3000/api

# URL racine du serveur - pour les fichiers uploadés (images, vidéos)
VITE_API_URL_ROOT=http://localhost:3000

# Webhook pour Google Sheets
VITE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbxXNtbJ2qNJYLMuFU55xY-1G-pChj454EFEm2AvJ03JlS81aU6jL3O2dNxI5vv06crhuw/exec